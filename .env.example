# ── Groww credentials ────────────────────────────────────────────────
# Pick ONE of the two auth styles below.
# (a) Daily access token minted on Groww's dashboard:
GROWW_API_TOKEN=
# (b) API Key + Secret — PennyWise exchanges these for a daily token at runtime:
GROWW_API_KEY=
GROWW_API_SECRET=

# ── LLM ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
PENNYWISE_LLM_MODEL=claude-opus-4-7

# Adaptive-thinking effort for the Synthesizer / Critic. low | medium | high.
# "medium" is the sweet spot for recommendation quality vs cost.
PENNYWISE_REASONING_EFFORT=medium

# ── Risk thresholds ──────────────────────────────────────────────────
PENNYWISE_HHI_FLAG=0.25
PENNYWISE_TOP_NAME_FLAG=0.20

# Market-cap bucketing per AMFI list (refresh biannually from
# amfiindia.com/research-information/other-data → "Categorization of Stocks").
# Values below are H1 2025 round numbers; replace with the current AMFI list.
PENNYWISE_LARGE_CAP_FLOOR_CR=80000
PENNYWISE_MID_CAP_FLOOR_CR=28000

# ── API backend (only needed for `docker-compose up`) ────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI registered in Google Cloud Console (Desktop app for CLI,
# Web app for the API backend). Add BOTH if using both surfaces:
#   http://localhost:18765/callback          ← CLI (pennywise login google)
#   http://localhost:8000/api/auth/google/callback  ← API backend
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
JWT_SECRET=pennywise-dev-secret-change-me
DYNAMODB_ENDPOINT=http://localhost:8042
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
