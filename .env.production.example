# ── PennyWise API — deployed environment contract ────────────────────
# This documents the variables the API expects in staging/prod. You do NOT
# create this file on a server: non-secret values come from the ECS task
# definition (set by Terraform), and secrets come from AWS Secrets Manager
# (injected by ECS). This file is the human-readable reference.

# Environment: staging | prod. Drives fail-closed checks + JSON logging.
PENNYWISE_ENV=prod

# ── Secrets (AWS Secrets Manager → injected by ECS, never in plaintext) ─
ANTHROPIC_API_KEY=          # secret: pennywise-<env>-anthropic-api-key
JWT_SECRET=                 # secret: pennywise-<env>-jwt-secret (Terraform-generated)
GOOGLE_CLIENT_ID=           # secret: pennywise-<env>-google-client-id
GOOGLE_CLIENT_SECRET=       # secret: pennywise-<env>-google-client-secret

# ── Non-secret config (ECS task definition env, set by Terraform) ─────
AWS_REGION=ap-south-1
PENNYWISE_TABLE_PREFIX=pennywise_prod_
# Real frontend origin(s) — NO localhost in prod.
CORS_ORIGINS=https://pennywise.app
# Must match the redirect URI registered in Google Cloud Console.
GOOGLE_REDIRECT_URI=https://api.pennywise.app/api/auth/google/callback

# ── LLM ──────────────────────────────────────────────────────────────
PENNYWISE_LLM_MODEL=claude-opus-4-8
PENNYWISE_REASONING_EFFORT=medium

# ── Rate limits (optional overrides) ─────────────────────────────────
PENNYWISE_RECO_RATE_LIMIT=5/hour
PENNYWISE_CHAT_TURNS_PER_WINDOW=30
PENNYWISE_CHAT_WINDOW_SECONDS=3600

# ── Logging ──────────────────────────────────────────────────────────
PENNYWISE_LOG_FORMAT=json
PENNYWISE_LOG_LEVEL=INFO

# NOTE: DYNAMODB_ENDPOINT is intentionally UNSET in AWS — boto3 uses the
# real regional endpoint and the task IAM role. Setting it would also
# trigger table auto-creation on boot, which prod must not do.
